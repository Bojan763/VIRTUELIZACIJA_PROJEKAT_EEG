<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<startup>
		<supportedRuntime version="v4.0"
						  sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<system.serviceModel>

		<bindings>
			<netTcpBinding>
				<binding name="eegBinding"
						 transferMode="Streamed"
						 maxReceivedMessageSize="10485760"
						 sendTimeout="00:05:00"
						 receiveTimeout="00:05:00">
				</binding>
			</netTcpBinding>
		</bindings>

		<client>

			<endpoint
			  name="EEGEndpoint"
			  address="net.tcp://localhost:9000/EEGService"
			  binding="netTcpBinding"
			  bindingConfiguration="eegBinding"
			  contract="Common.IEEGService" />

		</client>

	</system.serviceModel>

</configuration>