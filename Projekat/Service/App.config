<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<startup>
		<supportedRuntime version="v4.0"
						  sku=".NETFramework,Version=v4.7.2" />
	</startup>
	<appSettings>

		<add key="BatteryLowThreshold" value="20"/>

		<add key="ContactQualityMin" value="40"/>

		<add key="AttentionSpikeThreshold" value="90"/>

	</appSettings>

	<system.serviceModel>

		<bindings>
			<netTcpBinding>
				<binding name="eegBinding"
						 transferMode="Streamed"
						 maxReceivedMessageSize="10485760"
						 sendTimeout="00:05:00"
						 receiveTimeout="00:05:00">
				</binding>
			</netTcpBinding>
		</bindings>

		<services>
			<service name="Service.EEGService">

				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:9000" />
					</baseAddresses>
				</host>

				<endpoint
				  address="EEGService"
				  binding="netTcpBinding"
				  bindingConfiguration="eegBinding"
				  contract="Common.IEEGService" />

			</service>
		</services>

	</system.serviceModel>

</configuration>